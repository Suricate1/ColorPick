import javax.swing.*;
import javax.swing.border.EmptyBorder;
import javax.swing.filechooser.FileNameExtensionFilter;
import java.awt.*;
import java.awt.datatransfer.StringSelection;
import java.awt.event.*;
import java.awt.image.BufferedImage;
import java.io.*;
import java.nio.file.Files;
import java.nio.file.Path;
import java.text.DecimalFormat;
import java.util.List;
import java.util.ArrayList;
import java.util.stream.Collectors;
import javax.imageio.ImageIO;

public class ColorPicks extends JFrame {
    // UI elements
    private final JTextField hexField = new JTextField(9);
    private final JTextField rgbField = new JTextField(16);
    private final JTextField hslField = new JTextField(20);
    private final JPanel colorPreview = new JPanel();
    private final DefaultListModel<String> historyModel = new DefaultListModel<>();
    private final JList<String> historyList = new JList<>(historyModel);

    // Gradient
    private Color startColor = Color.WHITE;
    private Color endColor = Color.BLACK;
    private final GradientPanel gradientPreview = new GradientPanel();

    // History file
    private final Path historyFile = Path.of(System.getProperty("user.home"), ".ColorPicks_history.txt");

    // Uploaded image variables
    private BufferedImage loadedImage = null; // original
    private Image displayedImage = null;      // scaled for display in label
    private double imageScale = 1.0;          // displayed -> original scale
    private final JLabel imageLabel = new JLabel("", SwingConstants.CENTER);
    private final ImageMagnifierPanel magnifierPanel = new ImageMagnifierPanel();
    private final JSlider magnifierZoomSlider = new JSlider(2, 40, 12);

    // History swatches (color boxes)
    private final JPanel historySwatchesPanel = new JPanel(new FlowLayout(FlowLayout.LEFT, 6, 6));
    private final List<Color> historySwatches = new ArrayList<>();

    // Current color readouts
    private JPanel currentSwatchBox;
    private JButton copyHexBtn, copyRgbBtn;
    private JLabel fileInfoLabel;

    // Constructor
    public ColorPicks() {
        super("ColorPicks");
        setDefaultCloseOperation(EXIT_ON_CLOSE);
        setSize(1150, 760);
        setLocationRelativeTo(null);
        initUI();
        loadHistory(); // populate historyModel if file exists
    }

    private void initUI() {
        JPanel root = new JPanel(new BorderLayout(10,10));
        root.setBorder(new EmptyBorder(10,10,10,10));

        // LEFT: Tools panel
        JPanel tools = new JPanel();
        tools.setLayout(new BoxLayout(tools, BoxLayout.Y_AXIS));
        tools.setBorder(BorderFactory.createTitledBorder("Tools"));
        tools.setPreferredSize(new Dimension(220, 0));

        JButton uploadBtn = new JButton("Upload Image");
        uploadBtn.setAlignmentX(Component.LEFT_ALIGNMENT);
        uploadBtn.addActionListener(e -> uploadImage());

        JButton colorPickerBtn = new JButton("Color Picker");
        colorPickerBtn.setAlignmentX(Component.LEFT_ALIGNMENT);
        colorPickerBtn.addActionListener(e -> openColorPicker());

        // Gradient controls group
        JPanel gradientControls = new JPanel(new FlowLayout(FlowLayout.LEFT));
        JButton pickStartBtn = new JButton("Pick Start");
        pickStartBtn.addActionListener(e -> {
            Color c = JColorChooser.showDialog(this, "Choose Start Color", startColor);
            if (c != null) { startColor = c; updateFromColor(c); gradientPreview.setStartColor(c); gradientPreview.repaint(); }
        });
        JButton pickEndBtn = new JButton("Pick End");
        pickEndBtn.addActionListener(e -> {
            Color c = JColorChooser.showDialog(this, "Choose End Color", endColor);
            if (c != null) { endColor = c; updateFromColor(c); gradientPreview.setEndColor(c); gradientPreview.repaint(); }
        });
        JButton copyGradientCssBtn = new JButton("Copy Gradient CSS");
        copyGradientCssBtn.addActionListener(e -> copyToClipboard(generateGradientCSS()));
        gradientControls.add(pickStartBtn);
        gradientControls.add(pickEndBtn);
        gradientControls.add(copyGradientCssBtn);

        tools.add(uploadBtn);
        tools.add(Box.createVerticalStrut(6));
        tools.add(colorPickerBtn);
        tools.add(Box.createVerticalStrut(12));
        tools.add(new JLabel("Gradient Generator"));
        tools.add(gradientControls);
        tools.add(Box.createVerticalStrut(12));

        // Current color panel (fixed layout per request)
        JPanel currentPanel = new JPanel();
        currentPanel.setLayout(new BoxLayout(currentPanel, BoxLayout.Y_AXIS));
        currentPanel.setBorder(BorderFactory.createTitledBorder("Current Color"));
        currentSwatchBox = new JPanel();
        currentSwatchBox.setPreferredSize(new Dimension(160, 80));
        currentSwatchBox.setBorder(BorderFactory.createLineBorder(Color.BLACK));
        currentSwatchBox.setBackground(Color.WHITE);

        // HEX and RGB readouts (HEX under RGB as requested)
        JPanel readouts = new JPanel();
        readouts.setLayout(new BoxLayout(readouts, BoxLayout.Y_AXIS));
        hexField.setEditable(false);
        rgbField.setEditable(false);
        hslField.setEditable(false);
        JPanel hexRow = new JPanel(new FlowLayout(FlowLayout.LEFT));
        hexRow.add(new JLabel("HEX:"));
        hexRow.add(hexField);
        JPanel rgbRow = new JPanel(new FlowLayout(FlowLayout.LEFT));
        rgbRow.add(new JLabel("RGB:"));
        rgbRow.add(rgbField);
        JPanel hslRow = new JPanel(new FlowLayout(FlowLayout.LEFT));
        hslRow.add(new JLabel("HSL:"));
        hslRow.add(hslField);
        readouts.add(hexRow);
        readouts.add(rgbRow);
        readouts.add(hslRow);

        // Copy buttons side-by-side
        JPanel copyButtons = new JPanel(new FlowLayout(FlowLayout.LEFT));
        copyHexBtn = new JButton("Copy HEX");
        copyRgbBtn = new JButton("Copy RGB");
        copyHexBtn.addActionListener(e -> copyToClipboard(hexField.getText()));
        copyRgbBtn.addActionListener(e -> copyToClipboard(rgbField.getText()));
        copyButtons.add(copyHexBtn);
        copyButtons.add(copyRgbBtn);

        // File info label (size)
        fileInfoLabel = new JLabel("");

        currentPanel.add(currentSwatchBox);
        currentPanel.add(readouts);
        currentPanel.add(copyButtons);
        currentPanel.add(fileInfoLabel);

        tools.add(currentPanel);
        tools.add(Box.createVerticalGlue());

        // CENTER: Image area (large)
        JPanel center = new JPanel(new BorderLayout(6,6));
        center.setBorder(BorderFactory.createTitledBorder("Image"));

        imageLabel.setOpaque(true);
        imageLabel.setBackground(Color.LIGHT_GRAY);
        imageLabel.setHorizontalAlignment(SwingConstants.CENTER);
        imageLabel.setVerticalAlignment(SwingConstants.CENTER);
        imageLabel.setPreferredSize(new Dimension(760, 520));

        // Mouse listeners for magnifier sync and sampling
        imageLabel.addMouseMotionListener(new MouseMotionAdapter() {
            @Override public void mouseMoved(MouseEvent e) {
                if (loadedImage == null || displayedImage == null) return;

                int imgW = displayedImage.getWidth(null);
                int imgH = displayedImage.getHeight(null);

                int labelW = imageLabel.getWidth();
                int labelH = imageLabel.getHeight();

                // Calculate offsets (image centered in JLabel)
                int offsetX = (labelW - imgW) / 2;
                int offsetY = (labelH - imgH) / 2;

                int px = e.getX() - offsetX;
                int py = e.getY() - offsetY;

                if (px < 0 || py < 0 || px >= imgW || py >= imgH) return;

                int origX = (int) Math.round(px / imageScale);
                int origY = (int) Math.round(py / imageScale);

                origX = Math.max(0, Math.min(origX, loadedImage.getWidth() - 1));
                origY = Math.max(0, Math.min(origY, loadedImage.getHeight() - 1));

                magnifierPanel.setCenter(origX, origY, loadedImage);
                magnifierPanel.repaint();
                updateReadoutsOnly(origX, origY);
            }
        });

        imageLabel.addMouseListener(new MouseAdapter() {
            @Override public void mouseClicked(MouseEvent e) {
                if (loadedImage == null || displayedImage == null) return;

                int imgW = displayedImage.getWidth(null);
                int imgH = displayedImage.getHeight(null);

                int labelW = imageLabel.getWidth();
                int labelH = imageLabel.getHeight();

                int offsetX = (labelW - imgW) / 2;
                int offsetY = (labelH - imgH) / 2;

                int px = e.getX() - offsetX;
                int py = e.getY() - offsetY;

                if (px < 0 || py < 0 || px >= imgW || py >= imgH) return;

                int origX = (int) Math.round(px / imageScale);
                int origY = (int) Math.round(py / imageScale);

                origX = Math.max(0, Math.min(origX, loadedImage.getWidth() - 1));
                origY = Math.max(0, Math.min(origY, loadedImage.getHeight() - 1));

                Color c = new Color(loadedImage.getRGB(origX, origY), true);
                applyColor(c);
                addHistorySwatch(c);
            }
        });

        JScrollPane imageScroll = new JScrollPane(imageLabel);
        imageScroll.setPreferredSize(new Dimension(780, 540));
        center.add(imageScroll, BorderLayout.CENTER);

        // Magnifier under image
        JPanel magContainer = new JPanel(new BorderLayout(6,6));
        magContainer.setBorder(BorderFactory.createTitledBorder("Magnifier"));
        magnifierPanel.setPreferredSize(new Dimension(1080, 240));
        magnifierZoomSlider.setPreferredSize(new Dimension(220, 24));
        magnifierZoomSlider.addChangeListener(e -> {
            magnifierPanel.setZoom(magnifierZoomSlider.getValue());
            magnifierPanel.repaint();
        });
        JPanel magControls = new JPanel(new FlowLayout(FlowLayout.LEFT));
        magControls.add(new JLabel("Zoom:"));
        magControls.add(magnifierZoomSlider);
        magContainer.add(magnifierPanel, BorderLayout.CENTER);
        magContainer.add(magControls, BorderLayout.SOUTH);
        center.add(magContainer, BorderLayout.SOUTH);

        // RIGHT: History & Gradient (smaller)
        JPanel right = new JPanel(new BorderLayout(6,6));
        right.setBorder(BorderFactory.createTitledBorder("History"));
        right.setPreferredSize(new Dimension(260, 0));

        // History swatches (visual)
        JPanel histHolder = new JPanel(new BorderLayout());
        histHolder.add(new JScrollPane(historySwatchesPanel), BorderLayout.CENTER);
        JPanel histButtons = new JPanel(new FlowLayout(FlowLayout.LEFT));
        JButton saveHistBtn = new JButton("Save History");
        saveHistBtn.addActionListener(e -> saveHistory());
        JButton loadHistBtn = new JButton("Load History");
        loadHistBtn.addActionListener(e -> loadHistory());
        JButton clearHistBtn = new JButton("Clear");
        clearHistBtn.addActionListener(e -> {
            historyModel.clear();
            historySwatches.clear();
            historySwatchesPanel.removeAll();
            historySwatchesPanel.revalidate();
            historySwatchesPanel.repaint();
            try { Files.deleteIfExists(historyFile); } catch (IOException ex) {}
        });
        histButtons.add(saveHistBtn);
        histButtons.add(loadHistBtn);
        histButtons.add(clearHistBtn);
        histHolder.add(histButtons, BorderLayout.SOUTH);

        // Gradient preview small
        gradientPreview.setPreferredSize(new Dimension(240, 140));
        gradientPreview.setBorder(BorderFactory.createTitledBorder("Gradient Preview"));
        gradientPreview.setStartColor(startColor);
        gradientPreview.setEndColor(endColor);

        right.add(histHolder, BorderLayout.CENTER);
        right.add(gradientPreview, BorderLayout.SOUTH);

        // BOTTOM: export buttons
        JPanel bottom = new JPanel(new FlowLayout(FlowLayout.LEFT));
        JButton exportCssBtn = new JButton("Copy Color CSS");
        exportCssBtn.addActionListener(e -> copyToClipboard(generateColorCSS(hexField.getText())));
        JButton exportPngBtn = new JButton("Export Gradient PNG");
        exportPngBtn.addActionListener(e -> exportGradientAsPNG());
        bottom.add(exportCssBtn);
        bottom.add(exportPngBtn);

        // Compose root
        root.add(tools, BorderLayout.WEST);
        root.add(center, BorderLayout.CENTER);
        root.add(right, BorderLayout.EAST);
        root.add(bottom, BorderLayout.SOUTH);

        setContentPane(root);

        // Initialize defaults
        applyColor(Color.decode("#FFFFFF"));
    }

    // ----------------- Image upload & scaling -----------------
    private void uploadImage() {
        JFileChooser chooser = new JFileChooser();
        chooser.setFileFilter(new FileNameExtensionFilter("Images", ImageIO.getReaderFileSuffixes()));
        if (chooser.showOpenDialog(this) == JFileChooser.APPROVE_OPTION) {
            File f = chooser.getSelectedFile();
            try {
                BufferedImage img = ImageIO.read(f);
                if (img == null) { JOptionPane.showMessageDialog(this, "Invalid image file."); return; }
                loadedImage = img;
                // compute scale to fit imageLabel's viewport
                int maxW = 760, maxH = 520; // default area
                if (imageLabel.getParent() instanceof JViewport) {
                    Dimension vp = ((JViewport)imageLabel.getParent()).getExtentSize();
                    if (vp.width > 50 && vp.height > 50) { maxW = vp.width; maxH = vp.height; }
                }
                double scaleX = (double) maxW / img.getWidth();
                double scaleY = (double) maxH / img.getHeight();
                imageScale = Math.min(1.0, Math.min(scaleX, scaleY)); // do not upscale beyond 1.0
                int w = (int)Math.max(1, Math.round(img.getWidth()*imageScale));
                int h = (int)Math.max(1, Math.round(img.getHeight()*imageScale));
                displayedImage = img.getScaledInstance(w, h, Image.SCALE_SMOOTH);
                imageLabel.setIcon(new ImageIcon(displayedImage));
                imageLabel.setText("");
                // display file size
                long bytes = f.length();
                double kb = bytes / 1024.0;
                DecimalFormat df = new DecimalFormat("0.0");
                fileInfoLabel.setText("Image: " + img.getWidth() + "×" + img.getHeight() + "  |  " + df.format(kb) + " KB");
                // clear magnifier center
                magnifierPanel.setCenter(0, 0, loadedImage);
                magnifierPanel.repaint();
            } catch (IOException ex) {
                JOptionPane.showMessageDialog(this, "Failed to load image: " + ex.getMessage());
            }
        }
    }

    // ----------------- Readouts & apply color -----------------
    private void updateFromColor(Color c) {
        if (c == null) return;
        String hex = ColorUtils.colorToHex(c);
        hexField.setText(hex);
        rgbField.setText(String.format("rgb(%d, %d, %d)", c.getRed(), c.getGreen(), c.getBlue()));
        hslField.setText(ColorUtils.rgbToHslString(c));
        currentSwatchBox.setBackground(c);
    }

    private void updateReadoutsOnly(int origX, int origY) {
        if (loadedImage == null) return;
        if (origX < 0 || origY < 0 || origX >= loadedImage.getWidth() || origY >= loadedImage.getHeight()) return;
        Color c = new Color(loadedImage.getRGB(origX, origY), true);
        String hex = ColorUtils.colorToHex(c);
        hexField.setText(hex);
        rgbField.setText(String.format("rgb(%d, %d, %d)", c.getRed(), c.getGreen(), c.getBlue()));
        hslField.setText(ColorUtils.rgbToHslString(c));
    }

    private void applyColor(Color c) {
        updateFromColor(c);
        // add to historyModel textual list as well (keeps old save/load compatible)
        String hex = ColorUtils.colorToHex(c);
        if (!historyContains(hex)) historyModel.addElement(hex);
    }

    // ----------------- History swatches -----------------
    private boolean historyContains(String hex) {
        for (int i = 0; i < historyModel.size(); i++) if (historyModel.get(i).equalsIgnoreCase(hex)) return true;
        return false;
    }

    private void addHistorySwatch(Color c) {
        String hex = ColorUtils.colorToHex(c);
        // avoid duplicate by hex
        for (Color ec : historySwatches) {
            String eh = ColorUtils.colorToHex(ec);
            if (eh.equalsIgnoreCase(hex)) return;
        }

        historySwatches.add(0, c); // newest first
        JPanel sw = new JPanel();
        sw.setPreferredSize(new Dimension(34,34));
        sw.setBackground(c);
        sw.setBorder(BorderFactory.createLineBorder(Color.DARK_GRAY));
        sw.setToolTipText(hex);
        sw.addMouseListener(new MouseAdapter() {
            @Override public void mouseClicked(MouseEvent e) {
                applyColor(c);
                copyToClipboard(hex);
                // visual feedback: flash border
                Color orig = sw.getBackground();
                sw.setBorder(BorderFactory.createLineBorder(Color.WHITE, 3));
                Timer t = new Timer(180, ae -> { sw.setBorder(BorderFactory.createLineBorder(Color.DARK_GRAY)); ((Timer)ae.getSource()).stop(); });
                t.start();
            }
        });

        historySwatchesPanel.add(sw, 0);
        historySwatchesPanel.revalidate();
        historySwatchesPanel.repaint();

        // also add textual history for save/load compatibility
        if (!historyContains(hex)) historyModel.addElement(hex);
    }

    // ----------------- Utilities -----------------
    private void copyToClipboard(String s) {
        if (s == null || s.isBlank()) return;
        Toolkit.getDefaultToolkit().getSystemClipboard().setContents(new StringSelection(s), null);
        JOptionPane.showMessageDialog(this, "Copied: " + s);
    }

    private String generateColorCSS(String hex) {
        if (hex == null || hex.isBlank()) return "";
        return "--picked-color: " + hex + ";";
    }

    private String generateGradientCSS() {
        String s = ColorUtils.colorToHex(startColor);
        String e = ColorUtils.colorToHex(endColor);
        return "background: linear-gradient(90deg, " + s + ", " + e + ");";
    }

    private void exportGradientAsPNG() {
        JFileChooser fc = new JFileChooser();
        fc.setSelectedFile(new File("gradient.png"));
        if (fc.showSaveDialog(this) == JFileChooser.APPROVE_OPTION) {
            File out = fc.getSelectedFile();
            int w = 800, h = 200;
            BufferedImage img = new BufferedImage(w, h, BufferedImage.TYPE_INT_ARGB);
            Graphics2D g2 = img.createGraphics();
            GradientPaint gp = new GradientPaint(0, 0, startColor, w, 0, endColor);
            g2.setPaint(gp);
            g2.fillRect(0, 0, w, h);
            g2.dispose();
            try { ImageIO.write(img, "png", out); JOptionPane.showMessageDialog(this, "Exported to " + out.getAbsolutePath()); }
            catch (IOException ex) { JOptionPane.showMessageDialog(this, "Failed to export: " + ex.getMessage()); }
        }
    }

    // Save/load plain-text hex history (keeps compatibility)
    private void saveHistory() {
        try {
            HistoryManager.saveHistory(historyFile, historyModel);
            JOptionPane.showMessageDialog(this, "Saved history to " + historyFile);
        } catch (IOException e) {
            JOptionPane.showMessageDialog(this, "Failed to save: " + e.getMessage());
        }
    }

    private void loadHistory() {
        historyModel.clear();
        historySwatches.clear();
        historySwatchesPanel.removeAll();
        if (Files.exists(historyFile)) {
            try {
                List<String> lines = HistoryManager.loadHistory(historyFile);
                for (String l : lines) {
                    String hex = l.trim();
                    if (hex.isBlank()) continue;
                    historyModel.addElement(hex);
                    // add visual swatch too
                    try {
                        Color c = ColorUtils.hexToColor(hex);
                        addHistorySwatch(c);
                    } catch (Exception ignore) {}
                }
            } catch (IOException e) { /* ignore */ }
        }
    }

    // ----------------- Color Picker -----------------
    private void openColorPicker() {
        Color initial = colorPreview.getBackground() == null ? Color.WHITE : colorPreview.getBackground();
        Color chosen = JColorChooser.showDialog(this, "Pick a Color", initial);
        if (chosen != null) {
            applyColor(chosen);
            // add to history textual and visual
            String hex = ColorUtils.colorToHex(chosen);
            if (!historyContains(hex)) historyModel.addElement(hex);
            addHistorySwatch(chosen);
        }
    }

    // ----------------- Main -----------------
    public static void main(String[] args) {
        SwingUtilities.invokeLater(() -> {
            try { UIManager.setLookAndFeel(UIManager.getSystemLookAndFeelClassName()); } catch (Exception ignored) {}
            ColorPicks app = new ColorPicks();
            app.setVisible(true);
        });
    }
}
